      "cell_type": "code",
      "source": [
        "import asyncio\n",
        "import logging\n",
        "\n",
        "from aiogram import F\n",
        "from aiogram import Bot, Dispatcher, types\n",
        "from aiogram.filters.command import Command\n",
        "from aiogram.utils.keyboard import InlineKeyboardBuilder, ReplyKeyboardBuilder\n",
        "from google.colab import userdata\n",
        "from deep_translator import GoogleTranslator\n",
        "\n",
        "\n",
        "logging.basicConfig(level=logging.INFO)\n",
        "\n",
        "bot_token = userdata.get('SPACE_BOT_TOKEN')\n",
        "os.environ[\"SPACE_BOT_TOKEN\"] = bot_token\n",
        "\n",
        "bot = Bot(token=os.environ.get(\"SPACE_BOT_TOKEN\"))\n",
        "dp = Dispatcher()\n",
        "\n",
        "@dp.message(Command(\"start\"))\n",
        "async def cmd_start(message: types.Message):\n",
        "    await message.answer(\"Добро пожаловать.\\nВыберите, пожалуйста действие!!!\", reply_markup=create_keyboard())\n",
        "\n",
        "@dp.message(F.text == \"Инфо\")\n",
        "@dp.message(Command(\"help\"))\n",
        "async def help_command(message: types.Message):\n",
        "    info = (\n",
        "        \"База знаний об основоположниках космонавтики.\\n\"\n",
        "        f\"Число записей в базе знаний: {len(df)}\\n\"\n",
        "        \"Пример запроса: 'Кто первый полетел в Космос?.'\\n\\n\"\n",
        "        \"P.S.: База знаний на английском языке. Ответственность за перевод несет GoogleTranslator :)\"\n",
        "    )\n",
        "    await message.answer(info)\n",
        "\n",
        "\n",
        "@dp.message(F.text == \"Спроси меня\")\n",
        "async def ask_me(message: types.Message):\n",
        "    await message.answer(\"Спросите у меня что-нибудь про космонавтов\")\n",
        "\n",
        "@dp.message()\n",
        "async def answer(message: types.Message):\n",
        "    try:\n",
        "        translated_query = GoogleTranslator(source='ru', target='en').translate(message.text)\n",
        "        response_en = ask(translated_query)\n",
        "        response_ru = GoogleTranslator(source='en', target='ru').translate(response_en)\n",
        "        await message.answer(response_ru, reply_markup=create_keyboard())\n",
        "    except Exception as e:\n",
        "        await message.answer(f\"Произошла ошибка: {e}\", reply_markup=create_keyboard())\n",
        "\n",
        "def create_keyboard():\n",
        "    keyboard = ReplyKeyboardBuilder()\n",
        "    keyboard.add(types.KeyboardButton(text='Спроси меня'), types.KeyboardButton(text='Инфо'))\n",
        "    return keyboard.as_markup(resize_keyboard=True)\n",
        "\n",
        "async def main():\n",
        "    await dp.start_polling(bot)\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    asyncio.run(main())"
      ],
