        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Создано 85 заголовков статей в категории Category:Early_spaceflight_scientists.\n"
          ]
        }
      ],
      "source": [
        "CATEGORY_TITLE = \"Category:Early_spaceflight_scientists\"\n",
        "WIKI_SITE = \"en.wikipedia.org\"\n",
        "\n",
        "# Соберем заголовки всех статей\n",
        "def titles_from_category(category: mwclient.listing.Category, max_depth: int) -> set[str]:\n",
        "    titles = set()\n",
        "    try:\n",
        "        for cm in category.members():\n",
        "            if isinstance(cm, mwclient.page.Page):\n",
        "                titles.add(cm.name)\n",
        "            elif isinstance(cm, mwclient.listing.Category) and max_depth > 0:\n",
        "                deeper_titles = titles_from_category(cm, max_depth=max_depth - 1)\n",
        "                titles.update(deeper_titles)\n",
        "    except Exception as e:\n",
        "        print(f\"Произошла ошибка при получении членов категории: {e}\")\n",
        "    return titles\n",
        "\n",
        "site = mwclient.Site(WIKI_SITE)\n",
        "\n",
        "try:\n",
        "    category_page = site.pages[CATEGORY_TITLE]\n",
        "    titles = titles_from_category(category_page, max_depth=1)\n",
        "    print(f\"Создано {len(titles)} заголовков статей в категории {CATEGORY_TITLE}.\")\n",
        "except Exception as e:\n",
        "    print(f\"Произошла ошибка при загрузке страницы категории: {e}\")"
      ]
    },
